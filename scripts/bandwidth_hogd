#!/bin/bash

log=/var/log/alpenhorn/bandwidth_hogd.tsv.log
program="ionice -c2 -n5 rsync"

if [ ! -f $log ]; then
    # write the column header for file
    printf "date\ttransmitted_Bps\n" > $log
fi

while [ 1 ]; do
  rm -rf /chime/data/bandwidth_hog_data/
  res=`rsync -aptr --stats --rsync-path=$program -e "ssh -q" chime@192.139.21.135:/var/chime/bandwidth_hog_data/ /chime/data/bandwidth_hog_data/ 2>&1`
  if [ -z "`echo $res | grep error`" ]; then
    echo "`date``echo $res | awk '{printf("\t%s\n", $59);}'`" >> $log
  else
      echo "`date``printf "\tinterrupted\n" ` >> $log
  fi
done
